+    String output = mergedLines.isEmpty() ? "" : android.text.TextUtils.join("\n", mergedLines) + "\n";
+
+    try (FileOutputStream outputStream = new FileOutputStream(file, false)) {
+      outputStream.write(output.getBytes(StandardCharsets.UTF_8));
+    }
+  }
