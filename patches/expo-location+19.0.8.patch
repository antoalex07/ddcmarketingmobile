+  private fun keysToJsonArray(bundle: PersistableBundle?): JSONArray {
+    val keys = JSONArray()
+
+    if (bundle == null) {
+      return keys
+    }
+
+    for (key in bundle.keySet()) {
+      keys.put(key)
+    }
+
+    return keys
+  }
+
+  private fun valueType(bundle: PersistableBundle, key: String): String {
+    return try {
+      bundle.get(key)?.javaClass?.name ?: "null"
+    } catch (_: Exception) {
+      "unreadable"
+    }
+  }
+
+  private fun describeThrowable(error: Throwable): JSONObject {
+    val details = JSONObject()
+    details.put("error_name", error.javaClass.name)
+    details.put("error_message", error.message ?: "Unknown error")
+    details.put("stack", Log.getStackTraceString(error))
+    return details
+  }
+
+  private fun describePersistableLocationBundle(index: Int, bundle: PersistableBundle?): JSONObject {
+    val details = JSONObject()
+    details.put("index", index)
+    details.put("bundle_present", bundle != null)
+
+    if (bundle == null) {
+      return details
+    }
+
+    val coords = bundle.getPersistableBundle("coords")
+    details.put("keys", keysToJsonArray(bundle))
+    details.put("has_coords", coords != null)
+    details.put("timestamp_present", bundle.containsKey("timestamp"))
+    details.put("timestamp_type", if (bundle.containsKey("timestamp")) valueType(bundle, "timestamp") else "missing")
+
+    if (coords != null) {
+      details.put("coords_keys", keysToJsonArray(coords))
+      details.put("has_latitude", coords.containsKey("latitude"))
+      details.put("has_longitude", coords.containsKey("longitude"))
+      details.put("has_accuracy", coords.containsKey("accuracy"))
+      details.put("latitude_type", if (coords.containsKey("latitude")) valueType(coords, "latitude") else "missing")
+      details.put("longitude_type", if (coords.containsKey("longitude")) valueType(coords, "longitude") else "missing")
+    }
+
+    return details
+  }
+
+  private fun describeJobParams(params: JobParameters): JSONObject {
+    val details = JSONObject()
+
+    try {
+      val extras = params.extras
+      val dataSize = extras.getInt("dataSize", 0)
+      val data = JSONArray()
+
+      details.put("job_id", params.jobId)
+      details.put("extras_keys", keysToJsonArray(extras))
+      details.put("app_scope_key", extras.getString("appId"))
+      details.put("task_name", extras.getString("taskName"))
+      details.put("data_size", dataSize)
+
+      for (index in 0 until dataSize.coerceAtMost(5)) {
+        data.put(describePersistableLocationBundle(index, extras.getPersistableBundle(index.toString())))
+      }
+
+      details.put("data_preview", data)
+    } catch (error: Exception) {
+      details.put("describe_error", describeThrowable(error))
+    }
+
+    return details
+  }
